{
  "name": "bimdossier",
  "version": "0.0.1",
  "private": true,
  "description": "AI-based BIM takeoff platform supporting IFC and BCF",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "pnpm check:i18n && pnpm check:brand-tokens && turbo run lint",
    "check:i18n": "node scripts/check-i18n-parity.mjs",
    "check:brand-tokens": "node scripts/check-brand-tokens.mjs",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "eslint-plugin-i18next": "^6.1.4",
    "rimraf": "^5.0.10",
    "turbo": "^2.5.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "@opentelemetry/instrumentation": "0.214.0"
    },
    "patchedDependencies": {
      "@phosphor-icons/react": "patches/@phosphor-icons__react.patch",
      "next-themes@0.4.6": "patches/next-themes@0.4.6.patch"
    }
  },
  "packageManager": "pnpm@10.33.2"
}
