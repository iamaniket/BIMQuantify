# Template — copy to `.env` and fill in real values locally. `.env` is
# gitignored; this file is checked in. NEVER put real credentials, secrets,
# or tokens here. Per-app overrides live in apps/<name>/.env.

OPENAI_API_KEY=

# API base URL used by the Next.js frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional PostgreSQL database URL for persisting projects and takeoffs
DATABASE_URL=
