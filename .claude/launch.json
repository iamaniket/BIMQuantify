{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "portal",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "portal", "exec", "next", "dev", "--turbopack"],
      "port": 3001,
      "autoPort": true
    },
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "web", "exec", "next", "dev", "--turbopack"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "api",
      "runtimeExecutable": "uv",
      "runtimeArgs": [
        "--directory",
        "apps/api",
        "run",
        "uvicorn",
        "bimstitch_api.main:app",
        "--reload",
        "--port",
        "8000"
      ],
      "port": 8000,
      "autoPort": false
    },
    {
      "name": "processor",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "apps/processor", "run", "dev"],
      "port": 8088,
      "autoPort": false
    }
  ]
}
