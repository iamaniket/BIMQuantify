    "@types/react-dom": "^18.3.7",
    "rimraf": "^5.0.10",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@bim-quantify/ai-takeoff": "workspace:*",
    "@bim-quantify/bcf-parser": "workspace:*"
