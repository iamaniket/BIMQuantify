{
  "name": "@bim-quantify/bcf-parser",
  "version": "0.0.1",
  "private": true,
  "description": "BCF 2.1 zip parser for BIM collaboration issues",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
