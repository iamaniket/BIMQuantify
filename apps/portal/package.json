{
  "name": "portal",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "predev": "node scripts/copy-wasm.mjs && node ../../scripts/sync-brand-assets.mjs",
    "dev": "next dev --turbopack --port 3001",
    "prebuild": "node scripts/copy-wasm.mjs && node ../../scripts/sync-brand-assets.mjs",
    "build": "next build --webpack",
    "start": "next start --port 3001",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:admin": "playwright test tests/e2e/admin-blog.spec.ts --project=chromium --workers=1",
    "test:e2e:admin:ui": "playwright test tests/e2e/admin-blog.spec.ts --project=chromium --workers=1 --headed",
    "test:e2e:multi": "playwright test tests/e2e/multitenant.spec.ts --project=chromium --workers=1",
    "test:e2e:multi:ui": "playwright test tests/e2e/multitenant.spec.ts --project=chromium --workers=1 --headed",
    "test:e2e:request-access": "playwright test tests/e2e/request-access.spec.ts --project=chromium --workers=1",
    "test:e2e:request-access:ui": "playwright test tests/e2e/request-access.spec.ts --project=chromium --workers=1 --headed",
    "test:e2e:viewer": "playwright test tests/e2e/viewer.spec.ts --project=chromium --workers=1",
    "test:e2e:viewer:ui": "playwright test tests/e2e/viewer.spec.ts --project=chromium --workers=1 --headed",
    "test:e2e:templates": "playwright test tests/e2e/templates.spec.ts --project=chromium --workers=1",
    "test:e2e:templates:ui": "playwright test tests/e2e/templates.spec.ts --project=chromium --workers=1 --headed",
    "test:e2e:certificates": "playwright test tests/e2e/certificates.spec.ts --project=chromium --workers=1",
    "test:e2e:certificates:ui": "playwright test tests/e2e/certificates.spec.ts --project=chromium --workers=1 --headed",
    "test:e2e:login": "playwright test tests/login.spec.ts --project=chromium --workers=1",
    "test:e2e:login:ui": "playwright test tests/login.spec.ts --project=chromium --workers=1 --headed",
    "test:e2e:forgot-password": "playwright test tests/forgot-reset-password.spec.ts --project=chromium --workers=1",
    "test:e2e:forgot-password:ui": "playwright test tests/forgot-reset-password.spec.ts --project=chromium --workers=1 --headed",
    "test:e2e:full": "node scripts/run-e2e.mjs",
    "clean": "rimraf .next .turbo node_modules"
  },
  "dependencies": {
    "@bimdossier/annotation": "workspace:*",
    "@bimdossier/brand": "workspace:*",
    "@bimdossier/contracts": "workspace:*",
    "@bimdossier/design-tokens": "workspace:*",
    "@bimdossier/i18n": "workspace:*",
    "@bimdossier/map": "workspace:*",
    "@bimdossier/ui": "workspace:*",
    "@bimdossier/viewer": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.52.0",
    "@tanstack/react-query": "^5.62.0",
    "@thatopen/fragments": "~3.4.0",
    "exifr": "^7.1.3",
    "hash-wasm": "^4.12.0",
    "import-in-the-middle": "^3.0.1",
    "jwt-decode": "^4.0.0",
    "next": "^16.2.9",
    "next-intl": "^4.11.0",
    "next-themes": "^0.4.4",
    "posthog-js": "^1.378.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "react-markdown": "^9.0.1",
    "react-window": "^2.2.7",
    "remark-gfm": "^4.0.0",
    "require-in-the-middle": "^8.0.1",
    "sonner": "^2.0.7",
    "three": "^0.184.0",
    "uplot": "^1.6.30",
    "web-ifc": "0.0.77",
    "zod": "^3.24.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@bimdossier/eslint-config": "workspace:*",
    "@bimdossier/tailwind-config": "workspace:*",
    "@bimdossier/tsconfig": "workspace:*",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.4.49",
    "rimraf": "^5.0.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.9"
  }
}
