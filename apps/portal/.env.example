NEXT_PUBLIC_API_URL=http://localhost:8000

# Dev-only login form prefill. The portal reads these only in non-production
# builds (process.env.NODE_ENV !== 'production'); leave blank or remove the
# vars before deploying. Match these to the API's SEED_* values in your
# local `.env.local` (which is gitignored — never put real creds here).
NEXT_PUBLIC_DEV_LOGIN_EMAIL=
NEXT_PUBLIC_DEV_LOGIN_PASSWORD=

# Sentry (optional). Leave blank in dev to disable error reporting entirely.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

