NEXT_PUBLIC_API_URL=http://localhost:8000

# Dev-only login form prefill. The portal reads these only in non-production
# builds (process.env.NODE_ENV !== 'production'); leave blank or remove the
# vars before deploying. Match these to the API's SEED_* values in your
# local `.env.local` (which is gitignored — never put real creds here).
NEXT_PUBLIC_DEV_LOGIN_EMAIL=
NEXT_PUBLIC_DEV_LOGIN_PASSWORD=

# Sentry (optional). Leave blank in dev to disable error reporting entirely.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------------------------------------------------------------------------
# E2E Testing (Playwright)
# Used by `tests/support/global-setup.ts`. Override when running against
# non-default containers. `pnpm --filter=portal test:e2e:full` sets these
# automatically to point at docker-compose.test.yml services.
# ---------------------------------------------------------------------------
# E2E_DATABASE_URL=postgresql+asyncpg://bim:bim@localhost:5434/bimstitch_e2e
# E2E_REDIS_URL=redis://localhost:6380/2
# E2E_MAILHOG_URL=http://localhost:8025
# E2E_SMTP_PORT=1025
# E2E_S3_ENDPOINT=http://localhost:9000
# E2E_REDIS_CONTAINER=bimstitch-redis
# E2E_REDIS_DB=2
# E2E_API_PORT=8000

# Superadmin credentials for E2E login — same as API's SEED_SUPERADMIN_*.
# If unset, `tests/support/env.ts` reads them from apps/api/.env.
# SEED_SUPERADMIN_EMAIL=
# SEED_SUPERADMIN_PASSWORD=

