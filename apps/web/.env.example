NEXT_PUBLIC_PORTAL_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=https://bimdossier.nl

# PostHog product analytics (optional). Leave the key blank in dev to disable
# tracking entirely. Use the EU region host for GDPR data residency.
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Social / contact links rendered in the marketing-site footer "Connect"
# column. Each entry renders only when set; if all three are blank the
# whole column is hidden. Replace these with the real channels once the
# accounts are live.
NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=
NEXT_PUBLIC_SOCIAL_LINKEDIN_URL=
NEXT_PUBLIC_CONTACT_EMAIL=
