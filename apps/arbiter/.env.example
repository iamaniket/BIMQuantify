# Template — copy to `.env` and fill in real values locally. `.env` is
# gitignored; this file is checked in. NEVER put real credentials here.
# MinIO root key/secret live in docker-compose.yml — copy them into `.env`.
#
# S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY are REQUIRED (no code default): a
# missing value fails closed at startup so a forgotten prod var can never fall
# back to the public dev MinIO key. Outside docker, set them to the dev MinIO
# creds (bimdossier / bimdossier-secret).

S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_IFC=ifc-files

# Production is the default config posture. Set DEPLOY_REGION=dev to opt the
# local stack into the dev-config skip; a real deploy sets its region and the
# guard then refuses to boot on dev-default credentials.
DEPLOY_REGION=dev

ARBITER_HOST=0.0.0.0
ARBITER_PORT=8090
ARBITER_RULES_DIR=rules
