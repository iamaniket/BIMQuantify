# Template — copy to `.env` and fill in real values locally. `.env` is
# gitignored; this file is checked in. NEVER put real credentials here.
# MinIO root key/secret live in docker-compose.yml — copy them into `.env`.

S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_IFC=ifc-files

ARBITER_HOST=0.0.0.0
ARBITER_PORT=8090
ARBITER_RULES_DIR=rules
