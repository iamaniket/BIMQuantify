{
  "name": "processor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.1",
    "@aws-sdk/s3-request-presigner": "^3.658.1",
    "@fastify/sensible": "^6.0.1",
    "@sentry/node": "^10.52.0",
    "@thatopen/fragments": "~3.4.0",
    "bullmq": "^5.21.2",
    "dxf-parser": "^1.1.2",
    "exifr": "^7.1.3",
    "fastify": "^5.0.0",
    "fflate": "^0.8.2",
    "ioredis": "^5.4.1",
    "nodemailer": "^6.10.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.9.155",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "puppeteer-core": "^23.7.0",
    "three": "^0.184.0",
    "web-ifc": "0.0.77",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^6.4.17",
    "@types/three": "^0.184.0",
    "rimraf": "^5.0.10",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^2.1.6"
  }
}
