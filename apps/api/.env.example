# Template — copy to `.env` and fill in real values locally. `.env` is
# gitignored; this file is checked in. NEVER put real credentials, secrets,
# tokens, or passwords here. Keys with credential-shaped values are left
# blank below; non-credential config keeps its default.
#
# Dev defaults for local docker-compose services are documented in
# docker-compose.yml at the repo root (postgres user/pwd, MinIO root key,
# etc.). Copy them into your local .env after `cp .env.example .env`.

# Postgres connection strings. The dev docker-compose stack uses
# `bim:bim@localhost:5434/bimdossier` (and `bimdossier_test` for the suite).
DATABASE_URL=
TEST_DATABASE_URL=

# JWT signing secret. Must be long enough for HS256 (≥32 chars). Generate
# with `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
JWT_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
# Refresh-token rotation grace window (seconds). Every /auth/jwt/refresh rotates
# the refresh token and detects reuse (a replayed retired token signs the user
# out everywhere). Within this short window a retired token is re-honored
# idempotently so a benign cross-tab race / network retry doesn't trip reuse
# detection. Keep small. 0 disables the grace.
REFRESH_ROTATION_GRACE_SECONDS=30
# An open /ws/notifications socket re-authenticates on this interval (re-running the
# full handshake gate set) and is hard-capped at WS_MAX_LIFETIME_SECONDS, bounding
# post-revocation exposure to one interval. WS_MAX_LIFETIME_SECONDS must stay
# <= JWT_ACCESS_TTL_SECONDS (the production-config guard refuses to boot otherwise).
WS_REVALIDATE_INTERVAL_SECONDS=30
WS_MAX_LIFETIME_SECONDS=900
# Max concurrent /ws/notifications sockets per (org, user). Past this the handshake
# is refused with a 4029 close — guards against one member opening unbounded
# sockets (in-org DoS / memory growth). 10 covers real multi-tab / multi-device use.
WS_MAX_CONNECTIONS_PER_USER=10
# Super-admin impersonation access tokens are short-lived; this is the ceiling
# (POST /admin/impersonate/{user_id} clamps any request to <= this value).
IMPERSONATION_TOKEN_TTL_SECONDS=900

# Strict-Transport-Security max-age (seconds), sent only on https responses. The
# API gates HSTS on the request scheme (X-Forwarded-Proto via uvicorn
# --proxy-headers), so local http dev never receives it. 31536000 = 1 year.
# includeSubDomains is always added; preload is not (irreversible browser
# commitment). Lower this during initial TLS rollout, then raise back to a year.
HSTS_MAX_AGE_SECONDS=31536000

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@bimdossier.dev
# Hard ceiling (seconds) on one SMTP send. Bounds how long a hung/unreachable
# mail server can pin a request; transactional sends are best-effort so a timeout
# is logged and swallowed. aiosmtplib defaults to 60s without this.
SMTP_TIMEOUT_SECONDS=10

# Email transport selector: "smtp" (MailHog/dev or any SMTP server) or "postmark".
# Switch to postmark in prod for deliverability on compliance reminders.
EMAIL_TRANSPORT=smtp
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound

FRONTEND_VERIFY_URL=http://localhost:3000/auth/verify
FRONTEND_RESET_PASSWORD_URL=http://localhost:3001/reset-password
# Portal page where invited users see and accept/decline pending org invites.
FRONTEND_INVITATIONS_URL=http://localhost:3001/invitations

# Pending invitations older than this are swept to `removed` and free their seat.
# Resending an invite resets the timer.
INVITATION_TTL_DAYS=14
# How often the background sweeper runs. Set to 0 to disable in environments
# where another scheduler handles it (cron, k8s job, etc).
INVITATION_SWEEP_INTERVAL_MINUTES=60
# Days a soft-deleted org is retained (schema + storage kept, recoverable) before
# it is eligible for hard purge via `python -m bimdossier_api.scripts.purge_organizations`.
ORG_RETENTION_DAYS=30

CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# Optional regex for additional allowed origins (handy in dev when preview tools
# bind to ephemeral localhost ports). Leave blank in production.
CORS_ORIGIN_REGEX=^https?://localhost(:\d+)?$

# Redis backs rate limiting, the JWT blocklist, and the BullMQ job queue. It is
# LAUNCH-CRITICAL: on a Redis outage the rate limiter fails OPEN (throttling off)
# and the JWT blocklist fails CLOSED (all authed requests 401). In production
# REDIS_URL MUST point at a HIGHLY-AVAILABLE Redis (managed/replicated with
# automatic failover) with AOF persistence enabled — a single-node Redis is a
# single point of failure for the whole authenticated surface. (A localhost
# REDIS_URL outside dev triggers a non-fatal boot warning.)
REDIS_URL=redis://localhost:6380/0
TEST_REDIS_URL=redis://localhost:6380/1
# Max simultaneous Redis connections for rate-limiter + blocklist at scale.
REDIS_MAX_CONNECTIONS=50
# Fail fast (seconds, not a hang) when Redis is unreachable, and ping idle
# connections so the pool recovers after a failover without an app restart.
REDIS_SOCKET_TIMEOUT=2.0
REDIS_CONNECT_TIMEOUT=2.0
REDIS_HEALTH_CHECK_INTERVAL=30

RATE_LIMIT_LOGIN_PER_MIN=5
RATE_LIMIT_REFRESH_PER_MIN=10
RATE_LIMIT_FORGOT_PER_HOUR=3
# Per-IP/hour budget on the unauthenticated resend-activation endpoint
# (/auth/request-verify-token), which emails an activation link.
RATE_LIMIT_VERIFY_REQUEST_PER_HOUR=5
# Per-IP/hour budget on the public free-tier signup endpoint (/auth/signup),
# which emails an activation link to a new org-less account. Only active when
# FREE_TIER_ENABLED=true. Same email-bomb / enumeration posture as above.
RATE_LIMIT_SIGNUP_PER_HOUR=5
# Per-user/hour budgets on the expensive authenticated endpoints
# (synchronous compliance check, PDF report generation, upload presign,
# admin invite/resend email fan-out).
RATE_LIMIT_COMPLIANCE_PER_HOUR=20
RATE_LIMIT_REPORT_PER_HOUR=10
RATE_LIMIT_UPLOAD_INITIATE_PER_HOUR=100
RATE_LIMIT_INVITE_PER_HOUR=30
# Per-IP/hour budget on the PUBLIC capture-link upload-initiate (unauthenticated).
RATE_LIMIT_CAPTURE_INITIATE_PER_HOUR=120

# --- Account lockout (H6) ----------------------------------------------------
# Per-account failed-login throttle, independent of source IP. Stops distributed
# credential stuffing the per-IP RATE_LIMIT_LOGIN_PER_MIN cannot see. After
# LOGIN_LOCKOUT_MAX_ATTEMPTS failures within LOGIN_LOCKOUT_WINDOW_SECONDS the
# account locks for LOGIN_LOCKOUT_BASE_SECONDS, doubling per consecutive lockout
# up to LOGIN_LOCKOUT_MAX_SECONDS. Resets on successful login / password reset /
# super-admin unlock. Fails OPEN on a Redis outage (lockout off; password check
# still stands) so a Redis blip can't lock everyone out.
LOGIN_LOCKOUT_MAX_ATTEMPTS=10
LOGIN_LOCKOUT_WINDOW_SECONDS=900
LOGIN_LOCKOUT_BASE_SECONDS=900
LOGIN_LOCKOUT_MAX_SECONDS=86400

# --- Reverse proxy / forwarded headers ---------------------------------------
# Rate limits (and audit-log client IPs) key on the real caller IP. Behind a
# reverse proxy / load balancer the API's immediate peer is the proxy, and the
# real client arrives in X-Forwarded-For — which clients can forge. Trust XFF
# ONLY from known proxies, two layers:
#
# PRIMARY (uvicorn): FORWARDED_ALLOW_IPS is uvicorn's `--forwarded-allow-ips`.
# uvicorn (proxy_headers on by default) rewrites request.client.host from XFF
# only for peers in this list, so the app and audit logs both see the real
# client. Accepts IPs and CIDRs. Set it to the proxy/load-balancer subnet in
# prod (e.g. FORWARDED_ALLOW_IPS=10.0.0.0/8). The default loopback is correct
# for direct-to-host dev. NEVER use `*` in prod — it trusts XFF from any peer
# (spoofable); the production-config guard refuses to boot on `*`.
FORWARDED_ALLOW_IPS=127.0.0.1
# FALLBACK (app-level): TRUSTED_PROXY_IPS — comma-separated proxy IPs the rate
# limiter honors XFF from when uvicorn isn't given the env var above. Leave empty
# when uvicorn owns resolution (the recommended setup). `*` is rejected in prod.
# TRUSTED_PROXY_IPS=

S3_ENDPOINT_URL=http://localhost:9000
# Host baked into presigned URLs that *clients* (browser, mobile WebView) must
# reach. Defaults to S3_ENDPOINT_URL when blank, so dev is unchanged. Set this to
# a LAN IP or tunnel host for on-device testing — a phone can't reach the API's
# internal `localhost:9000`. The SigV4 signature covers the host, so the URL must
# be presigned against the host the client uses.
#   e.g. on-device dev:  S3_PUBLIC_ENDPOINT_URL=http://192.168.1.50:9000
# S3_PUBLIC_ENDPOINT_URL=
# CORS allow-list for the storage buckets (PutBucketCORS), decoupled from the
# API's CORS_ORIGINS. Falls back to CORS_ORIGINS when blank. The IFC bucket holds
# only presigned, credential-less objects, so "*" is safe here and lets the mobile
# WebView / iOS origins fetch model bytes without widening the API allow-list.
# (Dev MinIO honors its own MINIO_API_CORS_ALLOW_ORIGIN env var instead — see
# docker-compose.yml; this setting governs real S3 in production.)
# S3_CORS_ORIGINS=*
S3_REGION=us-east-1
# MinIO root key/secret from docker-compose.yml. Dev defaults:
#   MINIO_ROOT_USER=bimdossier / MINIO_ROOT_PASSWORD=bimdossier-secret
S3_ACCESS_KEY_ID=bimdossier
S3_SECRET_ACCESS_KEY=bimdossier-secret
S3_BUCKET_IFC=ifc-files
S3_PRESIGN_TTL_SECONDS=900
UPLOAD_MAX_BYTES=524288000
# Coarse global cap on the raw HTTP request body (RequestBodySizeLimitMiddleware).
# Large files bypass the API via presigned PUT to MinIO, so this is far smaller
# than UPLOAD_MAX_BYTES; the only large body that transits the API is a BCF import.
# 104857600 = 100 MiB.
REQUEST_BODY_MAX_BYTES=104857600
# Per-endpoint cap on the BCF import upload (parsed in-process). 52428800 = 50 MiB.
BCF_IMPORT_MAX_BYTES=52428800

# Postgres connection pool tuning. Defaults are sized for ~1000 concurrent
# users. Reduce in dev/CI if local Postgres has a lower max_connections.
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_TIMEOUT_SECONDS=30

PROCESSOR_URL=http://localhost:8088
# Address the processor calls back to. Stamped on each dispatched job so the
# worker reaches THIS API instance (multi-API / blue-green safe). Behind a
# proxy/LB set this to the internal service URL the processor can reach.
#
# IMPORTANT (dev): the processor runs inside Docker while the API runs on the
# host, and the worker now PREFERS this dispatched value over its own baked
# API_BASE_URL. So this must be a URL the *container* can reach the host on —
# `host.docker.internal`, NOT `localhost` (which would resolve to the container
# itself and the callback would never arrive). In prod set it to the real
# internal API URL the processor can reach.
API_BASE_URL=http://host.docker.internal:8000
# Shared bearer between API and the processor worker. Both services must
# agree; rotate by setting the same value in both .env files.
PROCESSOR_SHARED_SECRET=
PROCESSOR_DISPATCH_TIMEOUT_SECONDS=5.0
# Maximum concurrent pending/running jobs per tenant. Returns 429 when exceeded.
MAX_CONCURRENT_JOBS_PER_ORG=10
# Single-queue job priority by user tier (BullMQ: lower number = higher priority).
# Paying jobs sort ahead of free-tier jobs on the one shared `jobs` queue; the
# gap leaves room for a future paid sub-tier (~5). See jobs/priority.py.
JOB_PRIORITY_PAYING=10
JOB_PRIORITY_FREE=100
# Global cap on concurrent free-tier extractions (operationally JOB_CONCURRENCY-1)
# so free jobs can never occupy every processor slot. Enforced at the free
# dispatch site (free-wedge Phase 2); priority orders the queue but does not
# preempt a running job.
POOLED_EXTRACTION_CONCURRENCY_GLOBAL=1
# Master kill-switch for the entire free-tier ("free wedge") surface: public
# signup route mounting, every /pooled/* endpoint, the portal free-viewer route
# group. ON by default — the free tier is a launch surface; set false to ship
# dark (emergency off-switch).
FREE_TIER_ENABLED=true
# Per-model size cap for free uploads (D4); tenant cap stays UPLOAD_MAX_BYTES.
FREE_UPLOAD_MAX_BYTES=262144000
# Per-user model cap for the free tier (D6).
FREE_MAX_MODELS_PER_USER=10
# Per-user OWNED-project cap (shared-with-them projects don't count). Tunable so
# the free cohort allowance can be widened/narrowed without a code change.
FREE_MAX_PROJECTS_PER_USER=3
# Per-project INVITED-member cap (owner not counted; owner + cap = total seats).
FREE_MAX_MEMBERS_PER_PROJECT=9
# Per-user findings (snags) cap — LIFETIME semantics: counts every finding ever
# created (open, closed, and deleted); deletes do not free quota. Findings carry
# no storage bytes, so they escape the aggregate byte cap; this bounds the only
# otherwise-unbounded pooled write. Per-user overridable by a super-admin.
FREE_MAX_FINDINGS_PER_USER=2000
# Per-user AGGREGATE storage cap (3 GB): model files + photo evidence combined.
FREE_STORAGE_MAX_BYTES=3221225472
# Free-account TRIAL window in days (anchored on users.created_at). After it
# elapses only NEW-ASSET creation is blocked (new projects / containers /
# uploads 403 FREE_ACCOUNT_EXPIRED); snags, photos, invites and edits keep
# working forever on existing projects. Super-admin can override/exempt per
# account.
FREE_ACCOUNT_MAX_AGE_DAYS=90
# Per-user/hour presign churn on the free upload-initiate endpoint.
RATE_LIMIT_FREE_UPLOAD_INITIATE_PER_HOUR=30
# Per-user/hour write budget on free finding (snag) create + update.
RATE_LIMIT_FREE_FINDING_WRITE_PER_HOUR=120
# Per-user/hour budget on free snag-list PDF generation (puppeteer render on the
# shared processor).
RATE_LIMIT_FREE_REPORT_PER_HOUR=5
# Max concurrent in-flight free extractions per user (queued + running).
POOLED_EXTRACTION_CONCURRENCY_PER_USER=1
# Geometry tessellation threshold for the FREE extraction path — parity with
# paid (1 = every element meshed); the free cost controls are concurrency +
# queue priority, not geometry quality.
POOLED_JOB_GEOMETRY_THRESHOLD=1
# A free model with no viewer activity for this many days is reaped.
FREE_MODEL_IDLE_TTL_DAYS=90
# One-time warning email once a container has been idle this many days (must be
# < the TTL; 0 disables the warn pass). 76 leaves ~14 days notice before reap.
FREE_MODEL_IDLE_WARNING_DAYS=76
# How often the idle-free-model reaper runs (0 disables).
POOLED_IDLE_SWEEP_INTERVAL_MINUTES=360
# Reconciliation sweep: force-fails jobs/reports left non-terminal because a
# worker crashed or its callback never arrived. The stuck timeout must stay
# well above the worst-case legitimate runtime (JOB_TIMEOUT_MS x BullMQ
# retries). Set the interval to 0 to disable (e.g. when a cron handles it).
JOB_RECONCILE_INTERVAL_MINUTES=5
JOB_STUCK_TIMEOUT_MINUTES=60

# Data-lifecycle reapers. Abandoned pending uploads (initiated but never
# completed) older than PENDING_UPLOAD_TIMEOUT_MINUTES are soft-deleted and
# their object removed; expired/revoked capture links that were never used are
# hard-deleted. Set an interval to 0 to disable that sweep.
PENDING_UPLOAD_SWEEP_INTERVAL_MINUTES=30
PENDING_UPLOAD_TIMEOUT_MINUTES=1440
CAPTURE_LINK_SWEEP_INTERVAL_MINUTES=60

# Arbiter compliance MCP service.
ARBITER_URL=http://localhost:8090
ARBITER_TIMEOUT_SECONDS=30.0
# Shared bearer between the API and the Arbiter MCP server. Both services must
# agree; dev uses `dev-arbiter-secret-change-me` (set on the arbiter container in
# docker-compose.yml). The Arbiter reads the shared IFC bucket and rewrites rule
# packs, so an unauthenticated transport is a cross-tenant breach — this secret
# gates every MCP call. No code default: a missing value fails closed at startup.
ARBITER_SHARED_SECRET=

# Structured application logging. LOG_LEVEL is the root logger level
# (DEBUG/INFO/WARNING/...). LOG_FORMAT selects the stdout shape: "json" (one JSON
# object per line, for log aggregation) or "console" (human-readable, for dev).
# Left unset, LOG_FORMAT resolves to "json" in a production posture and "console"
# under DEPLOY_REGION=dev. Every line carries a request_id that ties an app log,
# the audit_log row, and the Sentry event for the same request together; the API
# also returns it as the X-Request-Id response header (generating one when the
# proxy didn't inject it).
LOG_LEVEL=INFO
# LOG_FORMAT=json

# Sentry (optional). Leave SENTRY_DSN blank to disable error reporting entirely.
# When set, every event is tagged with the request's request_id (same id as the
# logs / audit_log / X-Request-Id header) for cross-referencing.
SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Deployment metadata shown on the login page status badge (returned by
# /public/system-status) and the gate for the production-config guard.
#
# PRODUCTION IS THE DEFAULT POSTURE. If DEPLOY_REGION is unset (or set to any
# value other than "dev"), the API refuses to boot when S3_*/
# PROCESSOR_SHARED_SECRET / ARBITER_SHARED_SECRET still hold a dev value,
# CORS_ORIGINS contains "*", or JWT_SECRET is < 32 chars. Local dev must OPT IN
# explicitly with the line below; real deployments set their actual region (e.g.
# EU-WEST) and never ship dev secrets (S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY /
# PROCESSOR_SHARED_SECRET / ARBITER_SHARED_SECRET now have NO code default — a
# missing value fails closed at startup).
DEPLOY_REGION=dev
# DEPLOY_NODE=AMS01

# ---------------------------------------------------------------------------
# Seed users (dev only — consumed by `uv run python -m bimdossier_api.seed`).
# Every account is created with is_verified=True. Org membership and roles
# are structural and live in seed.py; only the credentials are sourced here.
#
# All twelve vars are REQUIRED. Leaving them blank here is intentional so
# this template never ships real creds. Set actual values in `.env` (which
# is gitignored). The seed script aborts with a clear pydantic
# ValidationError listing every missing key if any are unset.
# ---------------------------------------------------------------------------
SEED_SUPERADMIN_EMAIL=
SEED_SUPERADMIN_PASSWORD=

SEED_ACME_ADMIN_EMAIL=
SEED_ACME_ADMIN_PASSWORD=
SEED_ACME_EDITOR_EMAIL=
SEED_ACME_EDITOR_PASSWORD=
SEED_ACME_VIEWER_EMAIL=
SEED_ACME_VIEWER_PASSWORD=

SEED_BETA_ADMIN_EMAIL=
SEED_BETA_ADMIN_PASSWORD=

SEED_CROSS_EMAIL=
SEED_CROSS_PASSWORD=

# ---------------------------------------------------------------------------
# E2E Testing (Playwright)
# These vars are used by `apps/portal/tests/support/global-setup.ts` when
# running `pnpm --filter=portal test:e2e:multi:ci` against dev containers.
# For isolated test containers (`pnpm --filter=portal test:e2e:full`), the
# orchestrator script overrides these automatically.
#
# Defaults below assume the standard dev docker-compose stack on its usual
# ports. Override only when your local setup differs.
# ---------------------------------------------------------------------------
# E2E_DATABASE_URL=postgresql+asyncpg://bim:bim@localhost:5434/bimdossier_e2e
# E2E_REDIS_URL=redis://localhost:6380/2
# E2E_MAILHOG_URL=http://localhost:8025
# E2E_SMTP_PORT=1025
# E2E_S3_ENDPOINT=http://localhost:9000
# E2E_REDIS_CONTAINER=bimdossier-redis
# E2E_REDIS_DB=2
# E2E_API_PORT=8000
