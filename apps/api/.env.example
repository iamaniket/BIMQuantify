# Template — copy to `.env` and fill in real values locally. `.env` is
# gitignored; this file is checked in. NEVER put real credentials, secrets,
# tokens, or passwords here. Keys with credential-shaped values are left
# blank below; non-credential config keeps its default.
#
# Dev defaults for local docker-compose services are documented in
# docker-compose.yml at the repo root (postgres user/pwd, MinIO root key,
# etc.). Copy them into your local .env after `cp .env.example .env`.

# Postgres connection strings. The dev docker-compose stack uses
# `bim:bim@localhost:5434/bimstitch` (and `bimstitch_test` for the suite).
DATABASE_URL=
TEST_DATABASE_URL=

# JWT signing secret. Must be long enough for HS256 (≥32 chars). Generate
# with `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
JWT_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@bimstitch.dev

# Email transport selector: "smtp" (MailHog/dev or any SMTP server) or "postmark".
# Switch to postmark in prod for deliverability on compliance reminders.
EMAIL_TRANSPORT=smtp
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound

FRONTEND_VERIFY_URL=http://localhost:3000/auth/verify
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/auth/reset-password

CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# Optional regex for additional allowed origins (handy in dev when preview tools
# bind to ephemeral localhost ports). Leave blank in production.
CORS_ORIGIN_REGEX=^https?://localhost(:\d+)?$

REDIS_URL=redis://localhost:6380/0
TEST_REDIS_URL=redis://localhost:6380/1

RATE_LIMIT_LOGIN_PER_MIN=5
RATE_LIMIT_REGISTER_PER_HOUR=3
RATE_LIMIT_REFRESH_PER_MIN=10
RATE_LIMIT_FORGOT_PER_HOUR=3

S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
# MinIO root key/secret from docker-compose.yml — copy values from there
# into your local .env.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_IFC=ifc-files
S3_PRESIGN_TTL_SECONDS=900
UPLOAD_MAX_BYTES=2147483648

PROCESSOR_URL=http://localhost:8088
# Shared bearer between API and the processor worker. Both services must
# agree; rotate by setting the same value in both .env files.
PROCESSOR_SHARED_SECRET=
PROCESSOR_DISPATCH_TIMEOUT_SECONDS=5.0

# Sentry (optional). Leave SENTRY_DSN blank to disable error reporting entirely.
SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Deployment metadata shown on the login page status badge (returned by
# /public/system-status). Defaults to dev / local; set per-environment in
# your deploy config so the badge reflects the real region/node.
# DEPLOY_REGION=EU-WEST
# DEPLOY_NODE=AMS01

# ---------------------------------------------------------------------------
# Seed users (dev only — consumed by `uv run python -m bimstitch_api.seed`).
# Every account is created with is_verified=True. Org membership and roles
# are structural and live in seed.py; only the credentials are sourced here.
#
# All twelve vars are REQUIRED. Leaving them blank here is intentional so
# this template never ships real creds. Set actual values in `.env` (which
# is gitignored). The seed script aborts with a clear pydantic
# ValidationError listing every missing key if any are unset.
# ---------------------------------------------------------------------------
SEED_SUPERADMIN_EMAIL=
SEED_SUPERADMIN_PASSWORD=

SEED_ACME_ADMIN_EMAIL=
SEED_ACME_ADMIN_PASSWORD=
SEED_ACME_EDITOR_EMAIL=
SEED_ACME_EDITOR_PASSWORD=
SEED_ACME_VIEWER_EMAIL=
SEED_ACME_VIEWER_PASSWORD=

SEED_BETA_ADMIN_EMAIL=
SEED_BETA_ADMIN_PASSWORD=

SEED_CROSS_EMAIL=
SEED_CROSS_PASSWORD=
