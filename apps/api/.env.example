# Template — copy to `.env` and fill in real values locally. `.env` is
# gitignored; this file is checked in. NEVER put real credentials, secrets,
# tokens, or passwords here. Keys with credential-shaped values are left
# blank below; non-credential config keeps its default.
#
# Dev defaults for local docker-compose services are documented in
# docker-compose.yml at the repo root (postgres user/pwd, MinIO root key,
# etc.). Copy them into your local .env after `cp .env.example .env`.

# Postgres connection strings. The dev docker-compose stack uses
# `bim:bim@localhost:5434/bimstitch` (and `bimstitch_test` for the suite).
DATABASE_URL=
TEST_DATABASE_URL=

# JWT signing secret. Must be long enough for HS256 (≥32 chars). Generate
# with `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
JWT_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
# Super-admin impersonation access tokens are short-lived; this is the ceiling
# (POST /admin/impersonate/{user_id} clamps any request to <= this value).
IMPERSONATION_TOKEN_TTL_SECONDS=900

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@bimstitch.dev

# Email transport selector: "smtp" (MailHog/dev or any SMTP server) or "postmark".
# Switch to postmark in prod for deliverability on compliance reminders.
EMAIL_TRANSPORT=smtp
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound

FRONTEND_VERIFY_URL=http://localhost:3000/auth/verify
FRONTEND_RESET_PASSWORD_URL=http://localhost:3001/reset-password
# Portal page where invited users see and accept/decline pending org invites.
FRONTEND_INVITATIONS_URL=http://localhost:3001/invitations

# Pending invitations older than this are swept to `removed` and free their seat.
# Resending an invite resets the timer.
INVITATION_TTL_DAYS=14
# How often the background sweeper runs. Set to 0 to disable in environments
# where another scheduler handles it (cron, k8s job, etc).
INVITATION_SWEEP_INTERVAL_MINUTES=60

CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# Optional regex for additional allowed origins (handy in dev when preview tools
# bind to ephemeral localhost ports). Leave blank in production.
CORS_ORIGIN_REGEX=^https?://localhost(:\d+)?$

REDIS_URL=redis://localhost:6380/0
TEST_REDIS_URL=redis://localhost:6380/1
# Max simultaneous Redis connections for rate-limiter + blocklist at scale.
REDIS_MAX_CONNECTIONS=50

RATE_LIMIT_LOGIN_PER_MIN=5
RATE_LIMIT_REGISTER_PER_HOUR=3
RATE_LIMIT_REFRESH_PER_MIN=10
RATE_LIMIT_FORGOT_PER_HOUR=3
# Per-user/hour budgets on the expensive authenticated endpoints
# (synchronous compliance check, PDF report generation, upload presign).
RATE_LIMIT_COMPLIANCE_PER_HOUR=20
RATE_LIMIT_REPORT_PER_HOUR=10
RATE_LIMIT_UPLOAD_INITIATE_PER_HOUR=100

S3_ENDPOINT_URL=http://localhost:9000
# Host baked into presigned URLs that *clients* (browser, mobile WebView) must
# reach. Defaults to S3_ENDPOINT_URL when blank, so dev is unchanged. Set this to
# a LAN IP or tunnel host for on-device testing — a phone can't reach the API's
# internal `localhost:9000`. The SigV4 signature covers the host, so the URL must
# be presigned against the host the client uses.
#   e.g. on-device dev:  S3_PUBLIC_ENDPOINT_URL=http://192.168.1.50:9000
# S3_PUBLIC_ENDPOINT_URL=
# CORS allow-list for the storage buckets (PutBucketCORS), decoupled from the
# API's CORS_ORIGINS. Falls back to CORS_ORIGINS when blank. The IFC bucket holds
# only presigned, credential-less objects, so "*" is safe here and lets the mobile
# WebView / iOS origins fetch model bytes without widening the API allow-list.
# (Dev MinIO honors its own MINIO_API_CORS_ALLOW_ORIGIN env var instead — see
# docker-compose.yml; this setting governs real S3 in production.)
# S3_CORS_ORIGINS=*
S3_REGION=us-east-1
# MinIO root key/secret from docker-compose.yml. Dev defaults:
#   MINIO_ROOT_USER=bimstitch / MINIO_ROOT_PASSWORD=bimstitch-secret
S3_ACCESS_KEY_ID=bimstitch
S3_SECRET_ACCESS_KEY=bimstitch-secret
S3_BUCKET_IFC=ifc-files
S3_PRESIGN_TTL_SECONDS=900
UPLOAD_MAX_BYTES=524288000

# Postgres connection pool tuning. Defaults are sized for ~1000 concurrent
# users. Reduce in dev/CI if local Postgres has a lower max_connections.
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_TIMEOUT_SECONDS=30

PROCESSOR_URL=http://localhost:8088
# Shared bearer between API and the processor worker. Both services must
# agree; rotate by setting the same value in both .env files.
PROCESSOR_SHARED_SECRET=
PROCESSOR_DISPATCH_TIMEOUT_SECONDS=5.0
# Maximum concurrent pending/running jobs per tenant. Returns 429 when exceeded.
MAX_CONCURRENT_JOBS_PER_ORG=10
# Reconciliation sweep: force-fails jobs/reports left non-terminal because a
# worker crashed or its callback never arrived. The stuck timeout must stay
# well above the worst-case legitimate runtime (JOB_TIMEOUT_MS x BullMQ
# retries). Set the interval to 0 to disable (e.g. when a cron handles it).
JOB_RECONCILE_INTERVAL_MINUTES=5
JOB_STUCK_TIMEOUT_MINUTES=60

# Sentry (optional). Leave SENTRY_DSN blank to disable error reporting entirely.
SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Deployment metadata shown on the login page status badge (returned by
# /public/system-status). Defaults to dev / local; set per-environment in
# your deploy config so the badge reflects the real region/node.
#
# DEPLOY_REGION also gates the production-config guard: any value other than
# "dev" makes the API refuse to boot if S3_*/PROCESSOR_SHARED_SECRET are still
# the dev defaults, CORS_ORIGINS contains "*", or JWT_SECRET is < 32 chars.
# DEPLOY_REGION=EU-WEST
# DEPLOY_NODE=AMS01

# ---------------------------------------------------------------------------
# Seed users (dev only — consumed by `uv run python -m bimstitch_api.seed`).
# Every account is created with is_verified=True. Org membership and roles
# are structural and live in seed.py; only the credentials are sourced here.
#
# All twelve vars are REQUIRED. Leaving them blank here is intentional so
# this template never ships real creds. Set actual values in `.env` (which
# is gitignored). The seed script aborts with a clear pydantic
# ValidationError listing every missing key if any are unset.
# ---------------------------------------------------------------------------
SEED_SUPERADMIN_EMAIL=
SEED_SUPERADMIN_PASSWORD=

SEED_ACME_ADMIN_EMAIL=
SEED_ACME_ADMIN_PASSWORD=
SEED_ACME_EDITOR_EMAIL=
SEED_ACME_EDITOR_PASSWORD=
SEED_ACME_VIEWER_EMAIL=
SEED_ACME_VIEWER_PASSWORD=

SEED_BETA_ADMIN_EMAIL=
SEED_BETA_ADMIN_PASSWORD=

SEED_CROSS_EMAIL=
SEED_CROSS_PASSWORD=

# ---------------------------------------------------------------------------
# E2E Testing (Playwright)
# These vars are used by `apps/portal/tests/support/global-setup.ts` when
# running `pnpm --filter=portal test:e2e:multi:ci` against dev containers.
# For isolated test containers (`pnpm --filter=portal test:e2e:full`), the
# orchestrator script overrides these automatically.
#
# Defaults below assume the standard dev docker-compose stack on its usual
# ports. Override only when your local setup differs.
# ---------------------------------------------------------------------------
# E2E_DATABASE_URL=postgresql+asyncpg://bim:bim@localhost:5434/bimstitch_e2e
# E2E_REDIS_URL=redis://localhost:6380/2
# E2E_MAILHOG_URL=http://localhost:8025
# E2E_SMTP_PORT=1025
# E2E_S3_ENDPOINT=http://localhost:9000
# E2E_REDIS_CONTAINER=bimstitch-redis
# E2E_REDIS_DB=2
# E2E_API_PORT=8000
