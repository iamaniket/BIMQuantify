{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "description": "BIMQuantify Fastify API server",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "test": "jest --config jest.config.cjs",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@bim-quantify/ai-takeoff": "workspace:*",
    "@bim-quantify/bcf-parser": "workspace:*",
    "@bim-quantify/ifc-parser": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.1",
    "fastify": "^5.3.2"
  },
  "devDependencies": {
    "@bim-quantify/tsconfig": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.17.48",
    "jest": "^29.7.0",
    "rimraf": "^5.0.10",
    "ts-jest": "^29.3.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
