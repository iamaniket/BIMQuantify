# Build context for the web/portal Docker images is the REPO ROOT (they need the
# whole pnpm workspace to install + build @bimdossier/* deps). Keep the context
# lean: drop everything regenerated by install/build, plus VCS + local cruft.
#
# NB: do NOT ignore any workspace package.json or source — `pnpm install
# --frozen-lockfile` reads pnpm-workspace.yaml and needs every project present,
# or it aborts.

# Dependencies / package-manager state (reinstalled in the image)
**/node_modules
.pnpm-store

# Build outputs / caches (rebuilt in the image)
**/.next
**/.turbo
**/dist
**/out
**/build
**/*.tsbuildinfo

# Generated-at-build assets staged into public/ by predev/prebuild hooks
apps/web/public/brand
apps/web/public/fragments
apps/portal/public/brand
apps/portal/public/fragments
apps/portal/public/web-ifc

# Python API tooling (not needed to build the Next.js apps)
**/.venv
**/__pycache__
**/*.pyc
apps/api/.pytest_cache
apps/api/.ruff_cache
apps/api/.mypy_cache

# Tests / coverage / reports
**/coverage
**/test-results
**/playwright-report
**/.playwright

# VCS + editor + OS
.git
.gitignore
**/.DS_Store
.vscode
.idea

# Local env files — NEVER bake secrets into an image layer.
# NEXT_PUBLIC_* values are passed explicitly via build args instead.
**/.env
**/.env.*
!**/.env.example

# Docker / compose files themselves
**/Dockerfile
**/.dockerignore
docker-compose*.yml
